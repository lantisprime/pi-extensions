# Local optional SearXNG provider for the Pi web-search extension.
# Copy to .env or run ./init.sh before docker compose up.

# Use docker.io/searxng/searxng or ghcr.io/searxng/searxng.
SEARXNG_IMAGE=docker.io/searxng/searxng
SEARXNG_VERSION=latest

# Bind only to loopback by default. Do not expose this service publicly without
# adding HTTPS, authentication/rate limits, and reviewing SearXNG admin docs.
PI_SEARXNG_HOST=127.0.0.1
PI_SEARXNG_PORT=8080

# Replaced by ./init.sh. Required by SearXNG server settings.
SEARXNG_SECRET=replace-with-random-secret
